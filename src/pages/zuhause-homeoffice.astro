---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/layout/Breadcrumbs.astro";
import Hero from "../components/sections/Hero.astro";
import PainPoints from "../components/sections/PainPoints.astro";
import PricingGrid from "../components/sections/PricingGrid.astro";
import FaqAccordion from "../components/sections/FaqAccordion.astro";
import ContactWizard from "../components/islands/ContactWizard";
import PriceReadout from "../components/ui/PriceReadout.astro";
import { getService } from "../data/services";

const telefonHandgeraet = getService("telefon-handgeraet")!;
---

<BaseLayout
  title="WLAN-Hilfe zuhause in Senftenberg | Router, Repeater & Heimnetz"
  description="WLAN reicht nicht in alle Räume? WLANklar hilft zuhause in Senftenberg & Umgebung: Router prüfen, Repeater/Mesh einrichten, Smart-TV, Drucker & Homeoffice stabilisieren."
>
  <div class="container" style="padding-top: 20px;">
    <Breadcrumbs items={[{ label: "Startseite", href: "/" }, { label: "Zuhause & Homeoffice" }]} />
  </div>

  <Hero
    eyebrow="Zuhause & Homeoffice"
    title="WLAN-Hilfe zuhause in Senftenberg & Umgebung"
    lead="WLAN reicht nicht in alle Räume, Homeoffice-Calls brechen ab oder der Smart-TV lädt ständig nach? WLANklar hilft zuhause in Senftenberg, Großräschen, Lauchhammer, Schwarzheide, Ruhland, Lauta, Hoyerswerda und Umgebung."
    image={{ src: "/images/hero-wlan-check.webp", alt: "WLAN-Messung mit Tablet in einem Haus in der Lausitz" }}
    panelTitle="20 Jahre Erfahrung"
    panelItems={["Router, Repeater, Mesh und Powerline im Blick", "Passend für Wohnung, Haus und Homeoffice"]}
    ctas={[{ href: "#kontakt", label: "Termin anfragen" }]}
  />

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Heimnetz prüfen</span>
        <h2>Router, Repeater, Mesh und Endgeräte vor Ort verstehen</h2>
        <p class="lead">
          Wir prüfen Router, WLAN-Signal, Repeater, Mesh, Powerline und wichtige Endgeräte vor Ort. Danach wissen Sie,
          ob eine bessere Platzierung reicht, Einstellungen geändert werden müssen oder ob Access Point, LAN-Brücke oder
          Mesh sinnvoller sind.
        </p>
      </div>
      <div class="grid cols-3">
        <div class="panel">
          <h3>Router einrichten in Senftenberg & Umgebung</h3>
          <p style="color: var(--color-ink-muted);">
            Sinnvoll nach Anbieterwechsel, Routertausch oder wenn WLAN-Name, Passwort, Telefonie und Geräte neu sortiert
            werden müssen.
          </p>
        </div>
        <div class="panel">
          <h3>Repeater oder Mesh-WLAN einrichten</h3>
          <p style="color: var(--color-ink-muted);">
            Repeater, Mesh oder Access Point werden dort geprüft und platziert, wo sie wirklich helfen.
          </p>
        </div>
        <div class="panel">
          <h3>Smart-TV, Streaming und WLAN-Verbindung prüfen</h3>
          <p style="color: var(--color-ink-muted);">
            Wenn Fernseher, Streaming-Stick, Drucker oder Laptop die Verbindung verlieren, wird das Gerät zusammen mit
            dem Heimnetz betrachtet.
          </p>
        </div>
      </div>
      <div class="btn-row" style="margin-top: 24px;">
        <a class="btn btn-secondary" href="/wlan-techniker-senftenberg/">WLAN-Techniker in Senftenberg</a>
        <a class="btn btn-secondary" href="/repeater-mesh-einrichten-senftenberg/">Repeater oder Mesh-WLAN einrichten</a>
        <a class="btn btn-secondary" href="/drucker-einrichten-senftenberg/">Drucker im WLAN einrichten</a>
      </div>
    </div>
  </section>

  <PainPoints
    eyebrow="Kommt Ihnen bekannt vor?"
    title="Typische Probleme zuhause und im Homeoffice."
    points={[
      "WLAN reicht nicht in alle Räume",
      "Repeater bringt nichts",
      "Homeoffice-Calls brechen ab",
      "Smart-TV ruckelt beim Streaming",
      "Glasfaser ist da, WLAN bleibt schwach",
      "Drucker wird nicht gefunden",
      "Geräte verbinden sich falsch",
      "Mesh oder Powerline: unklar was passt",
      "Nach Routerwechsel herrscht Chaos",
      "Zu viele WLAN-Namen im Haus",
    ]}
  />

  <PricingGrid
    eyebrow="Preise"
    title="Klare Pakete für Zuhause und Homeoffice."
    note="Wird aus dem WLAN-Check & Soforthilfe direkt das Komplettpaket, zahlen Sie nicht 99 € + 199 €, sondern 199 € gesamt. Neue Geräte kommen nur nach Absprache dazu."
    serviceIds={["wlan-check", "wlan-soforthilfe", "stabiles-heimnetz"]}
  />

  <section class="section" style="padding-block: 0 0;">
    <div class="container">
      <div class="panel" style="display: flex; flex-wrap: wrap; gap: 24px; align-items: center; justify-content: space-between;">
        <div style="flex: 1 1 260px;">
          <strong>Sie wissen schon genau, was Sie brauchen?</strong>
          <p style="margin: 4px 0 0; color: var(--color-ink-muted);">
            Dann reicht oft eine einzelne Einrichtung unten – ohne Ursachensuche.
          </p>
        </div>
        <div style="flex: 1 1 260px;">
          <strong>Sie wissen nicht, woran es liegt?</strong>
          <p style="margin: 4px 0 0; color: var(--color-ink-muted);">
            Dann ist das Angebot WLAN-Check & Soforthilfe oben der richtige Start – wir finden die Ursache für Sie.
          </p>
        </div>
      </div>
    </div>
  </section>

  <PricingGrid
    eyebrow="Kleine schnelle Hilfe"
    title="Feste Einzelleistungen, wenn die Ursache schon klar ist."
    note="Für ein vorhandenes kompatibles Gerät, das nur eingerichtet werden muss – kein Ursachen-Check enthalten. Zusätzliche Wünsche oder weiterer Zeitaufwand werden vorab besprochen und nur nach Zustimmung berechnet."
    serviceIds={["router-basis", "repeater-basis", "smart-tv"]}
  />

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Zusatzleistung</span>
        <h2>DECT-Telefon oder zusätzliches Handgerät einrichten</h2>
        <p class="lead">
          Ein zusätzliches schnurloses Telefon im Schlafzimmer, Büro oder Obergeschoss kann praktisch sein – besonders,
          wenn der Router bereits DECT unterstützt. WLANklar prüft beim Router- oder Heimnetztermin, ob Ihre vorhandene
          Technik geeignet ist, richtet das Handgerät ein und testet die Verbindung vor Ort.
        </p>
      </div>
      <div class="panel" style="max-width: 460px;">
        <h3>Schnurloses Telefon im Haus verbinden und testen</h3>
        <p style="color: var(--color-ink-muted);">{telefonHandgeraet.tagline}</p>
        <PriceReadout
          price={telefonHandgeraet.price}
          priceFrom={telefonHandgeraet.priceFrom}
          priceSuffix={telefonHandgeraet.priceSuffix}
        />
        {telefonHandgeraet.includes.map((line) => <p class="price-callout">{line}</p>)}
        <div style="margin-top: 16px;">
          <a class="btn btn-small" href={`/kontakt/?leistung=${telefonHandgeraet.id}`}>Beim WLAN-Termin mit anfragen</a>
        </div>
      </div>
    </div>
  </section>

  <FaqAccordion
    ids={[
      "was-kostet-es",
      "check-garantie",
      "vorbereitung",
      "kein-routerzugang",
      "vorhandene-geraete",
      "telefon-einrichten",
      "neue-hardware-pflicht",
    ]}
  />

  <section class="section section-alt" id="kontakt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Kontakt</span>
        <h2>Schildern Sie kurz, was nicht zuverlässig funktioniert.</h2>
      </div>
      <div class="panel">
        <ContactWizard client:load defaultObjectType="Zuhause/Homeoffice" />
      </div>
    </div>
  </section>
</BaseLayout>
