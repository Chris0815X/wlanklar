---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Seite nicht gefunden" description="Diese Seite wurde nicht gefunden." noIndex>
  <section class="section">
    <div class="container" style="max-width: 560px; text-align: center;">
      <span class="section-label">404</span>
      <h1>Diese Seite gibt es nicht (mehr).</h1>
      <p class="lead">Vielleicht hilft Ihnen einer dieser Einstiege weiter.</p>
      <div class="btn-row" style="justify-content: center;">
        <a class="btn" href="/">Zur Startseite</a>
        <a class="btn btn-secondary" href="/kontakt/">Termin anfragen</a>
      </div>
    </div>
  </section>
</BaseLayout>
