---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/layout/Breadcrumbs.astro";
import Hero from "../components/sections/Hero.astro";
import PainPoints from "../components/sections/PainPoints.astro";
import PricingGrid from "../components/sections/PricingGrid.astro";
import FaqAccordion from "../components/sections/FaqAccordion.astro";
import ContactWizard from "../components/islands/ContactWizard";
import { faqPageSchema, serviceSchema } from "../data/schema";

const faqIds = [
  "fewo-check-soforthilfe",
  "fewo-getrenntes-gaeste-wlan",
  "fewo-qr-code",
  "fewo-monteurzimmer",
  "fewo-anwesenheit",
  "hardware-im-preis",
];
const schemas = [
  serviceSchema({
    name: "Gäste-WLAN für Ferienwohnungen im Lausitzer Seenland",
    serviceType: "Gäste-WLAN, WLAN-QR-Code, Smart-TV-Check und Gästeinfos",
    url: "/ferienwohnungen/",
    areaServed: "Senftenberg, Großkoschen, Geierswalde und Lausitzer Seenland",
  }),
  faqPageSchema(faqIds),
];
---

<BaseLayout
  title="Gäste-WLAN Ferienwohnung Lausitzer Seenland | QR-Code & Smart-TV"
  description="Gäste-WLAN, WLAN-QR-Code, Smart-TV-Check und klare Gästeinfos für Ferienwohnungen, Monteurzimmer & Pensionen rund um Senftenberg, Großkoschen, Geierswalde und Lausitzer Seenland."
  schemas={schemas}
>
  <div class="container" style="padding-top: 20px;">
    <Breadcrumbs items={[{ label: "Startseite", href: "/" }, { label: "Ferienwohnungen & Monteurzimmer" }]} />
  </div>

  <Hero
    eyebrow="Ferienwohnungen & Monteurzimmer"
    title="Gäste-WLAN für Ferienwohnungen im Lausitzer Seenland"
    lead="Gäste erwarten heute, dass WLAN, Smart-TV und Zugangsdaten sofort funktionieren – besonders in Ferienwohnungen am Senftenberger See, in Großkoschen, Geierswalde, Senftenberg und im Lausitzer Seenland."
    image={{ src: "/images/ferienwohnung-gaeste-wlan.webp", alt: "Gäste-WLAN-Karte mit QR-Code für eine Ferienwohnung im Lausitzer Seenland" }}
    panelTitle="Besonders sinnvoll für"
    panelItems={["Gastgeber und Vermieter", "Monteurzimmer", "kleine Pensionen", "Objekte mit wiederkehrenden Gästeanfragen"]}
    ctas={[{ href: "#kontakt", label: "Termin anfragen" }]}
  />

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Gastgeber</span>
        <h2>Weniger Rückfragen zu WLAN, QR-Code und Smart-TV</h2>
        <p class="lead">
          WLANklar richtet Gäste-WLAN, WLAN-QR-Code, Smart-TV und klare Gästeinfos so ein, dass weniger Rückfragen
          entstehen und Ihre Unterkunft professioneller wirkt.
        </p>
      </div>
      <div class="panel">
        <p style="margin: 0; color: var(--color-ink-muted);">
          Besonders sinnvoll ist das für Ferienwohnungen, Monteurzimmer, kleine Pensionen und Gastgeber, die nicht
          ständig wegen WLAN-Passwort, Streaming oder Verbindungsproblemen erreichbar sein möchten.
        </p>
      </div>
    </div>
  </section>

  <PainPoints
    eyebrow="Kommt Ihnen bekannt vor?"
    title="Typische Probleme bei Ferienwohnungen."
    points={[
      "WLAN-Passwort ist nicht auffindbar",
      "Kein QR-Code für Gäste",
      "Smart-TV macht Probleme",
      "WLAN-Signal ist zu schwach",
      "Gäste-WLAN ist nicht vom eigenen Netz getrennt",
      "Schlechte Bewertung wegen Technik",
      "Saisonstart ohne Check",
      "Monteurzimmer-WLAN instabil",
      "Gästemappe ist veraltet",
      "Servicepersonal braucht klare Infos",
    ]}
  />

  <PricingGrid
    eyebrow="Angebote"
    title="Prüfen, direkt verbessern oder sauber neu aufsetzen."
    note="Schon der Einstieg liefert ein konkretes Ergebnis: einfache Korrekturen, einen digitalen WLAN-QR-Code und eine kurze Zusammenfassung. Bei größerem Bedarf wird der Check auf Gäste-WLAN Komfort angerechnet. Alle genannten Preise sind Bruttopreise inklusive Mehrwertsteuer."
    columns={2}
    serviceIds={["gastgeber-check", "gaeste-wlan-komfort", "saisonstart-check"]}
  />

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Mehrere Unterkünfte</span>
        <h2>Mehrere Objekte? Ein Ansprechpartner.</h2>
        <p class="lead">
          Sie betreuen mehrere Ferienwohnungen, Monteurzimmer, eine kleine Pension oder eine Ferienanlage? WLANklar
          prüft die Objekte strukturiert, vereinheitlicht Gäste-WLAN, QR-Codes und Dokumentation und erstellt ein
          passendes Angebot für Ihren Bestand.
        </p>
      </div>
      <div class="grid cols-2">
        <div class="panel">
          <ul style="margin: 0; padding-left: 18px; color: var(--color-ink-muted);">
            <li>abgestimmte Prüfung mehrerer Objekte</li>
            <li>einheitliche Gäste-WLAN-Karten und QR-Codes</li>
            <li>nachvollziehbare Dokumentation für Vermieter oder Servicepersonal</li>
          </ul>
        </div>
        <div class="panel">
          <ul style="margin: 0; padding-left: 18px; color: var(--color-ink-muted);">
            <li>gemeinsame Terminplanung</li>
            <li>individuelles Angebot abhängig von Objektzahl und Ausgangssituation</li>
          </ul>
        </div>
      </div>
      <div class="btn-row" style="margin-top: 24px;">
        <a class="btn" href="#kontakt">Mehrere Objekte anfragen</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Region</span>
        <h2>WLAN-Service für Ferienwohnungen rund um den Senftenberger See</h2>
        <p class="lead">
          Rund um Senftenberg, Großkoschen, Geierswalde, Lauta, Elsterheide und das Lausitzer Seenland ist
          funktionierendes WLAN für Gäste ein wichtiger Teil der Unterkunft. WLANklar prüft, ob Router, Repeater, Mesh
          oder Smart-TV sinnvoll eingerichtet sind und ob Gäste wirklich unkompliziert online gehen können.
        </p>
      </div>
      <div class="panel">
        <p style="margin: 0; color: var(--color-ink-muted);">
          Auf Wunsch erhalten Sie einen WLAN-QR-Code, eine kurze Gästeanleitung, eine Vermieter-Dokumentation und ein
          gedrucktes Gäste-WLAN-Set mit klaren Hinweisen für die Unterkunft.
        </p>
      </div>
      <div class="btn-row" style="margin-top: 24px;">
        <a class="btn btn-secondary" href="/gaeste-wlan-ferienwohnung-lausitzer-seenland/">Gäste-WLAN im Lausitzer Seenland ansehen</a>
        <a class="btn btn-secondary" href="/wlan-techniker-senftenberg/">WLAN-Techniker in Senftenberg</a>
        <a class="btn btn-secondary" href="/ratgeber/gaeste-wlan-ferienwohnung/">Ratgeber Gäste-WLAN lesen</a>
      </div>
    </div>
  </section>

  <FaqAccordion ids={faqIds} />

  <section class="section" id="kontakt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Kontakt</span>
        <h2>Schildern Sie kurz, was für Ihre Unterkunft wichtig ist.</h2>
      </div>
      <div class="panel">
        <ContactWizard client:load defaultObjectType="Ferienwohnung/Monteurzimmer" />
      </div>
    </div>
  </section>
</BaseLayout>
