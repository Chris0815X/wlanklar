---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../data/config";
---

<BaseLayout title="Impressum" description="Impressum von WLANklar." noIndex>
  <section class="section">
    <div class="container legal-page" style="max-width: 720px;">
      <p><a href="/">Zurück zur Startseite</a></p>
      <h1>Impressum</h1>
      <div class="panel">
        <p><strong>Angaben gemäß § 5 Digitale-Dienste-Gesetz (DDG)</strong></p>
        <p>
          {siteConfig.brandName}<br />
          {siteConfig.legalForm}<br />
          Inhaber: {siteConfig.ownerName}<br />
          {siteConfig.street}<br />
          {siteConfig.postcode} {siteConfig.city}<br />
          Deutschland
        </p>

        <h2>Kontakt</h2>
        <p>
          Telefon: <a href={`tel:${siteConfig.phone}`}>{siteConfig.phoneDisplay}</a><br />
          E-Mail: <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
        </p>

        <h2>Umsatzsteuer-ID</h2>
        <p>
          Umsatzsteuer-Identifikationsnummer gemäß § 27a Umsatzsteuergesetz:<br />
          {siteConfig.vatId}
        </p>

        <h2>Redaktionell verantwortlich</h2>
        <p>
          Verantwortlich für journalistisch-redaktionelle Inhalte gemäß § 18 Abs. 2 Medienstaatsvertrag:<br />
          {siteConfig.ownerName}<br />
          {siteConfig.street}<br />
          {siteConfig.postcode} {siteConfig.city}
        </p>

        <h2>Verbraucherstreitbeilegung</h2>
        <p>
          WLANklar ist nicht bereit und nicht verpflichtet, an Streitbeilegungsverfahren vor einer
          Verbraucherschlichtungsstelle teilzunehmen.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
