---
// Vertrauens-Sektion mit Ansprechpartnerbild und persönlicher Ansprache,
// um die Anonymität einer reinen Firmen-Website aufzubrechen.
import { freeCallCta } from "../../lib/whatsapp";

const call = freeCallCta();
---

<section class="section section-alt">
  <div class="container">
    <div class="trust-profile">
      <div class="trust-profile-photo">
        <img
          src="/images/ansprechpartner-wlanklar-original.png"
          alt="Ihr Ansprechpartner bei WLANklar"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="trust-profile-body">
        <span class="section-label">Wer kommt zu Ihnen?</span>
        <h2>Kein anonymes Team – ein fester Ansprechpartner.</h2>
        <p class="lead">
          Über 20 Jahre Erfahrung mit Netzwerktechnik, IT sowie Hard- und Software. Ich komme persönlich zu Ihnen –
          ob zuhause, in der Ferienwohnung oder im Betrieb. Kein wechselndes Personal, kein anonymes Callcenter: Sie
          sprechen vorher und nachher mit derselben Person, die auch vor Ort war.
        </p>
        <div class="btn-row">
          <a class="btn" href={call.href}>{call.label}</a>
        </div>
        <p class="hero-micro">In 5–10 Minuten am Telefon klären, ob und was sich lohnt – unverbindlich und kostenlos.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .trust-profile {
    display: grid;
    grid-template-columns: minmax(220px, 320px) 1fr;
    gap: clamp(24px, 5vw, 48px);
    align-items: center;
  }

  .trust-profile-photo {
    width: min(100%, 320px);
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-md);
    background: var(--color-surface);
  }

  .trust-profile-photo img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 640px) {
    .trust-profile {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }

    .trust-profile .btn-row {
      justify-content: center;
    }

    .trust-profile-photo {
      width: min(100%, 280px);
    }
  }
</style>
