---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/layout/Breadcrumbs.astro";
import Hero from "../components/sections/Hero.astro";
import PainPoints from "../components/sections/PainPoints.astro";
import PricingGrid from "../components/sections/PricingGrid.astro";
import FaqAccordion from "../components/sections/FaqAccordion.astro";
import ContactWizard from "../components/islands/ContactWizard";
---

<BaseLayout
  title="WLAN für Büro, Praxis & Studio in Senftenberg | Kunden-WLAN"
  description="WLANklar richtet WLAN, Kunden-WLAN und Netzwerkverbindungen für Drucker, Scanner, Kartenterminals und Arbeitsplatzgeräte in kleinen Büros, Praxen, Studios & Salons im Raum Senftenberg ein."
>
  <div class="container" style="padding-top: 20px;">
    <Breadcrumbs items={[{ label: "Startseite", href: "/" }, { label: "Kleine Büros, Praxen & Studios" }]} />
  </div>

  <Hero
    eyebrow="Kleine Büros, Praxen & Studios"
    title="WLAN und Kunden-WLAN für kleine Büros, Praxen & Studios in Senftenberg"
    lead="Wenn Kunden-WLAN fehlt, das Kartenterminal die Netzwerkverbindung verliert, der Drucker nicht gefunden wird oder das WLAN bis in Nebenräume nicht reicht, hilft WLANklar kleinen Betrieben im Raum Senftenberg pragmatisch vor Ort."
    micro="WLAN · Kunden-WLAN · Kartenterminal-Verbindung · Drucker/Scanner · Tablet · Kassen-PC · einfache Dokumentation"
    image={{ src: "/images/buero-wlan-check.webp", alt: "WLAN-Check für Kunden-WLAN in einem kleinen Büro in Senftenberg" }}
    panelTitle="Unser Schwerpunkt"
    panelItems={["WLAN & Kunden-WLAN", "Drucker & Arbeitsplatzgeräte", "Termine auch außerhalb der Öffnungszeiten"]}
    ctas={[{ href: "#kontakt", label: "Jetzt Termin anfragen" }]}
  />

  <PainPoints
    eyebrow="Kommt Ihnen bekannt vor?"
    title="Typische Probleme in kleinen Betrieben."
    points={[
      "Kunden-WLAN fehlt oder ist nicht getrennt",
      "Kartenterminal verliert die Netzwerkverbindung",
      "Drucker wird nicht gefunden",
      "Terminsoftware ist bei instabiler Verbindung nicht zuverlässig erreichbar",
      "WLAN reicht nicht bis in Nebenräume",
      "Repeater bringt nichts",
      "Nach Routerwechsel funktioniert nichts mehr",
      "Musik oder TV bricht ab",
      "Zu viele WLAN-Namen",
      "Es soll einfach zuverlässig laufen",
    ]}
  />

  <PricingGrid
    eyebrow="Angebote"
    title="Prüfen, einfache Probleme direkt lösen und klar weiterplanen."
    note="Schon der Einstieg enthält Soforthilfe vor Ort. Wird daraus direkt das Büro-WLAN Setup, wird der Check angerechnet. Alle Gewerbepreise sind Bruttopreise inklusive Mehrwertsteuer."
    columns={2}
    serviceIds={["buero-check", "buero-setup"]}
  />

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Alltag im Betrieb</span>
        <h2>Was im kleinen Betrieb wirklich funktionieren muss</h2>
        <p class="lead">
          Der Fokus liegt auf Router, WLAN, Gäste- oder Kunden-WLAN, Drucker, Scanner, Arbeitsplatzgeräten, Kasse,
          Tablet, Musik, Smart-TV und einfacher Dokumentation.
        </p>
      </div>
      <div class="grid cols-3">
        <div class="panel">
          <h3>Kunden-WLAN sauber getrennt einrichten</h3>
          <p style="color: var(--color-ink-muted);">
            Für Praxis, Studio, Salon, Büro oder kleinen Laden: Gäste und Kunden sollen online gehen können, ohne
            Zugriff auf interne Geräte oder Arbeitsdaten zu erhalten.
          </p>
        </div>
        <div class="panel">
          <h3>Drucker, Scanner und Arbeitsplatzgeräte verbinden</h3>
          <p style="color: var(--color-ink-muted);">
            WLANklar prüft, warum Drucker, Scanner, Kassen-PC, Tablet oder Laptop nicht zuverlässig im Netzwerk
            erreichbar sind, und bindet die Geräte nach Möglichkeit sauber ein.
          </p>
        </div>
        <div class="panel">
          <h3>WLAN-Abdeckung im Betrieb verbessern</h3>
          <p style="color: var(--color-ink-muted);">
            Wenn Nebenräume, Behandlungszimmer, Wartebereich oder Lager schlechten Empfang haben, wird geprüft, ob
            Routerstandort, Repeater, Mesh, Access Point oder Kabelverbindung sinnvoll sind.
          </p>
        </div>
      </div>
      <div class="btn-row" style="margin-top: 24px;">
        <a class="btn btn-secondary" href="/drucker-einrichten-senftenberg/">Drucker einrichten</a>
        <a class="btn btn-secondary" href="/wlan-techniker-senftenberg/">WLAN-Techniker Senftenberg</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Leistungsumfang</span>
        <h2>Unser Schwerpunkt – und was darüber hinaus geht.</h2>
      </div>
      <div class="grid cols-3">
        <div class="panel">
          <h3>WLAN & Gästezugang</h3>
          <p style="color: var(--color-ink-muted);">Router prüfen, Kunden-WLAN sauber getrennt einrichten, Abdeckung verbessern.</p>
        </div>
        <div class="panel">
          <h3>Drucker & Arbeitsplatzgeräte</h3>
          <p style="color: var(--color-ink-muted);">Drucker, Scanner, Kassen- und Arbeitsplatzgeräte zuverlässig anbinden.</p>
        </div>
        <div class="panel">
          <h3>Kleine Projekte nach Absprache</h3>
          <p style="color: var(--color-ink-muted);">
            Sie brauchen etwas darüber hinaus? Sprechen Sie uns an – kleinere Projekte setzen wir nach individueller
            Absprache gern um.
          </p>
        </div>
      </div>
    </div>
  </section>

  <FaqAccordion
    ids={["buero-check-soforthilfe", "buero-projekte", "buero-branchensoftware", "buero-netto", "buero-termin", "nachbetreuung"]}
  />

  <section class="section" id="kontakt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Kontakt</span>
        <h2>Schildern Sie kurz, was in Ihrem Betrieb nicht läuft.</h2>
      </div>
      <div class="panel">
        <ContactWizard client:load defaultObjectType="kleines Büro/Praxis/Studio" />
      </div>
    </div>
  </section>
</BaseLayout>
