---
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import MobileStickyCta from "../components/layout/MobileStickyCta.astro";
import AttributionInit from "../components/islands/AttributionInit.astro";
import { SITE_URL } from "../data/config";
import { localBusinessSchema } from "../data/schema";
import "../styles/global.css";

type JsonLdSchema = Record<string, unknown>;

interface Props {
  title: string;
  description: string;
  includeSchema?: boolean;
  noIndex?: boolean;
  canonical?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  schemas?: JsonLdSchema | (JsonLdSchema | null | undefined)[];
  publishedTime?: Date | string;
  modifiedTime?: Date | string;
}

const {
  title,
  description,
  includeSchema = false,
  noIndex = false,
  canonical,
  ogType = "website",
  ogImage,
  schemas,
  publishedTime,
  modifiedTime,
} = Astro.props;
const siteUrl = (Astro.site ?? new URL(SITE_URL)).toString();
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, siteUrl);
const ownSchema = includeSchema ? [localBusinessSchema(canonicalUrl.origin)] : [];
const passedSchemas = (Array.isArray(schemas) ? schemas : [schemas]).filter(Boolean) as JsonLdSchema[];
const schemaList = [...ownSchema, ...passedSchemas];
const pageTitle = title.includes("WLANklar") ? title : `${title} – WLANklar`;
const absoluteOgImage = ogImage ? new URL(ogImage, siteUrl) : null;
const publishedIso = publishedTime instanceof Date ? publishedTime.toISOString() : publishedTime;
const modifiedIso = modifiedTime instanceof Date ? modifiedTime.toISOString() : modifiedTime;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex,follow" />}
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {absoluteOgImage && <meta property="og:image" content={absoluteOgImage} />}
    {ogType === "article" && publishedIso && <meta property="article:published_time" content={publishedIso} />}
    {ogType === "article" && modifiedIso && <meta property="article:modified_time" content={modifiedIso} />}
    <meta name="twitter:card" content={absoluteOgImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {absoluteOgImage && <meta name="twitter:image" content={absoluteOgImage} />}
    {schemaList.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
    ))}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <MobileStickyCta />
    <AttributionInit />
  </body>
</html>
