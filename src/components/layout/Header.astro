---
import BrandMark from "../ui/BrandMark.astro";
import { siteConfig } from "../../data/config";

const navItems = [
  { href: "/zuhause-homeoffice/", label: "Zuhause" },
  { href: "/ferienwohnungen/", label: "Ferienwohnungen" },
  { href: "/kleine-bueros/", label: "Büros" },
  { href: "/technik-hilfe/", label: "Technik-Hilfe" },
  { href: "/einsatzgebiet/", label: "Einsatzgebiet" },
  { href: "/ratgeber/", label: "Ratgeber" },
];
---

<header class="site-header">
  <div class="container">
    <a class="brand" href="/">
      <BrandMark class="brand-mark" />
      {siteConfig.brandName}
    </a>
    <nav class="site-nav" aria-label="Hauptnavigation">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
    <div class="header-cta">
      <a class="btn btn-small" href="/kontakt/">Termin anfragen</a>
      <details class="mobile-nav">
        <summary class="mobile-nav-toggle" aria-label="Menü öffnen">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </summary>
        <nav class="mobile-nav-panel" aria-label="Mobile Hauptnavigation">
          {navItems.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>
      </details>
    </div>
  </div>
</header>
