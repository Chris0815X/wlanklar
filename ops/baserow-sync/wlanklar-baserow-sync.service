[Unit]
Description=WLANklar lead sync from Netlify to Baserow
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
DynamicUser=yes
EnvironmentFile=/etc/wlanklar-baserow-sync.env
ExecStart=/usr/bin/node /opt/wlanklar-baserow-sync/sync.mjs
NoNewPrivileges=yes
PrivateTmp=yes
ProtectHome=yes
ProtectSystem=strict
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes

[Install]
WantedBy=multi-user.target
