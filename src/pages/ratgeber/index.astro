---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/layout/Breadcrumbs.astro";

const posts = (await getCollection("ratgeber", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
  title="Ratgeber"
  description="Verständliche Antworten auf häufige WLAN-, Heimnetz- und Gäste-WLAN-Fragen aus der Praxis von WLANklar."
>
  <section class="section">
    <div class="container">
      <Breadcrumbs items={[{ label: "Startseite", href: "/" }, { label: "Ratgeber" }]} />
      <div class="section-head">
        <span class="section-label">Ratgeber</span>
        <h1>Verständliche Antworten statt Technikfloskeln.</h1>
      </div>
      <div class="grid cols-3">
        {posts.map((post) => (
          <a class="panel" href={`/ratgeber/${post.id}/`} style="text-decoration: none; color: inherit;">
            <h3>{post.data.title}</h3>
            <p style="color: var(--color-ink-muted);">{post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
