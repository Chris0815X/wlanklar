---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/layout/Breadcrumbs.astro";
import { articleSchema } from "../data/schema";
import { getService } from "../data/services";

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  relatedServiceIds?: string[];
  segments?: string[];
}

const { title, description, publishDate, updatedDate, relatedServiceIds = [], segments = [] } = Astro.props;

const segmentLinks: Record<string, { label: string; href: string }> = {
  privat: { label: "Zuhause & Homeoffice", href: "/zuhause-homeoffice/" },
  ferienwohnung: { label: "Ferienwohnungen & Monteurzimmer", href: "/ferienwohnungen/" },
  buero: { label: "Kleine Büros, Praxen & Studios", href: "/kleine-bueros/" },
};

const relatedServices = relatedServiceIds.map((id) => getService(id)).filter(Boolean);
const schemas = [
  articleSchema({
    headline: title,
    description,
    publishDate,
    updatedDate,
    url: Astro.url.pathname,
  }),
];
const isFerienwohnungPost = segments.includes("ferienwohnung");
const ctaCopy = isFerienwohnungPost
  ? "Wenn Sie Gäste-WLAN, QR-Code oder Smart-TV nicht selbst vorbereiten möchten, hilft WLANklar vor Ort im Lausitzer Seenland."
  : "Wenn Sie das Problem nicht selbst eingrenzen möchten, hilft WLANklar mit einem WLAN-Check vor Ort in Senftenberg und Umgebung.";
const ctaLink = isFerienwohnungPost
  ? { href: "/gaeste-wlan-ferienwohnung-lausitzer-seenland/", label: "Gäste-WLAN im Lausitzer Seenland ansehen" }
  : { href: "/wlan-techniker-senftenberg/", label: "WLAN-Check in Senftenberg anfragen" };
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  publishedTime={publishDate}
  modifiedTime={updatedDate}
  schemas={schemas}
>
  <article class="section">
    <div class="container" style="max-width: 720px;">
      <Breadcrumbs items={[{ label: "Startseite", href: "/" }, { label: "Ratgeber", href: "/ratgeber/" }, { label: title }]} />
      <span class="section-label">
        {publishDate.toLocaleDateString("de-DE", { year: "numeric", month: "long", day: "numeric" })}
      </span>
      <h1>{title}</h1>
      <div class="lead" style="margin-bottom: 32px;">
        <slot />
      </div>

      <div class="panel" style="margin-bottom: 24px;">
        <h2 style="font-size: var(--step-h3);">Hilfe vor Ort</h2>
        <p style="color: var(--color-ink-muted);">{ctaCopy}</p>
        <a class="btn btn-small" href={ctaLink.href}>{ctaLink.label}</a>
      </div>

      {(relatedServices.length > 0 || segments.length > 0) && (
        <div class="panel">
          <h3>Das könnte Sie auch interessieren</h3>
          <div class="btn-row">
            {segments.map((segment) => segmentLinks[segment] && (
              <a class="btn btn-secondary btn-small" href={segmentLinks[segment].href}>
                {segmentLinks[segment].label}
              </a>
            ))}
            {relatedServices.map((service) => (
              <a class="btn btn-secondary btn-small" href={`/kontakt/?leistung=${service!.id}`}>
                {service!.name}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>
