---
// Vertrauens-Sektion: bewusst ohne Namen, aber mit Gesicht (Platzhalterbild bis echtes Foto vorliegt)
// und persönlicher Ansprache, um die Anonymität einer reinen Firmen-Website aufzubrechen.
import { freeCallCta } from "../../lib/whatsapp";

const call = freeCallCta();
---

<section class="section section-alt">
  <div class="container">
    <div class="trust-profile">
      <div class="trust-profile-photo">
        <img src="/images/ansprechpartner-platzhalter.svg" alt="Ihr Ansprechpartner bei WLANklar (Platzhalterbild)" />
      </div>
      <div class="trust-profile-body">
        <span class="section-label">Wer kommt zu Ihnen?</span>
        <h2>Kein anonymes Team – ein fester Ansprechpartner.</h2>
        <p class="lead">
          Über 20 Jahre Erfahrung mit Netzwerktechnik, IT sowie Hard- und Software. Ich komme persönlich zu Ihnen –
          ob zuhause, in der Ferienwohnung oder im Betrieb. Kein wechselndes Personal, kein anonymes Callcenter: Sie
          sprechen vorher und nachher mit derselben Person, die auch vor Ort war.
        </p>
        <div class="btn-row">
          <a class="btn" href={call.href}>{call.label}</a>
        </div>
        <p class="hero-micro">In 5–10 Minuten am Telefon klären, ob und was sich lohnt – unverbindlich und kostenlos.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .trust-profile {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: clamp(24px, 5vw, 48px);
    align-items: center;
  }

  .trust-profile-photo {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-md);
  }

  .trust-profile-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 640px) {
    .trust-profile {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }

    .trust-profile .btn-row {
      justify-content: center;
    }
  }
</style>
